<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="/nav.css">
    <link
      href="https://fonts.googleapis.com/css2?family=Boldonse&family=Edu+NSW+ACT+Cursive:wght@400..700&family=Montserrat:ital,wght@0,100..900;1,100..900&family=Nata+Sans:wght@100..900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"
    />
    <title>AirBnB</title>

    <style>
      h1 {
        margin-top: 20px;
        text-align: center;
      }
      .container_box {
        margin: 30px auto;
        width: 300px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        justify-content: center;
        align-items: flex-start;
        border: 1px solid #ddd;
        border-radius: 10px;
        padding: 15px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.1);
      }
      form button{
          padding: 10px;
          border-radius: 10px;
          font-size: 1.2rem;
          border: none;
      }
      form button:hover{
          background-color: #842A3B;
          color:white;
      }
    </style>
  </head>

  <body>
    <%- include('partials/nav') %>

    <h1>Welcome to AirBnB</h1>

    <% if (users && users.length === 0) { %>
      <h2 style="text-align:center;">No home registered yet</h2>
    <% } else { %>
      <h2 style="text-align:center;">Registered Homes</h2>

      <% users.forEach((home, index) => { %>
        <div class="container_box">
          <p><strong>ID:</strong> <%= index + 1 %></p>
          <p><strong>Name:</strong> <%= home.name %></p>
          <p><strong>Price:</strong> ₹<%= home.price %></p>
          <p><strong>Contact:</strong> <%= home.contact %></p>
          <p><strong>Location:</strong> <%= home.location %></p>
          <form action="/homes_details" method="POST" >
           <button type="submit">Home Details</button>
          </form>
        </div>
      <% }) %>

    <% } %>

  </body>
</html>
